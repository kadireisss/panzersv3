# ═══════════════════════════════════════════════════════════════════════════
# PANZER V3 — Eksiksiz ortam şablonu (Vercel “Import .env” veya yerel .env için)
# ═══════════════════════════════════════════════════════════════════════════
# Kullanım: kopyala → .env adıyla kaydet; gizlileri doldur; .env’i asla Git’e ekleme.
# Vercel: Settings → Environment Variables → “Import .env” ile yükle (Production + Preview seç).

# ─── Supabase (zorunlu) ───────────────────────────────────────────────────
# Project URL: Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://mdoffvnavmjvxfsyznfr.supabase.co
# Sunucu-only tercih (tarayıcıya gitmez); boş bırakılabilir; doluysa API tarafı da kullanır
SUPABASE_URL=https://mdoffvnavmjvxfsyznfr.supabase.co
# Settings → API → service_role (Secret) — TEK SATIR, tırnaksız yapıştır
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_FROM_SUPABASE_DASHBOARD
# Storage bucket adı (projede oluşturduğun isimle aynı olmalı)
SUPABASE_STORAGE_BUCKET=panzer-uploads

# ─── JWT oturum imzası (zorunlu) ──────────────────────────────────────────
# En az 32 karakter; örnek üretim: openssl rand -hex 32   (PowerShell: -join ((48..57+97..122)|% {[char]$_}|Get-Random -Count 48))
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ─── Webhook / güvenlik ───────────────────────────────────────────────────
# İlk Vercel deploy sonrası gerçek domaininle değiştir ve env’i kaydedip Redeploy et
WEBHOOK_BASE_URL=https://YOUR_PROJECT_NAME.vercel.app
# setup-webhooks?secret=... ile eşleşmeli; üret ve unutma
WEBHOOK_SETUP_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# ─── Telegram (opsiyonel; boş bırakılabilir — çoğu token panel DB’den de okunur) ─
ADMIN_BOT_TOKEN=
ADMIN_BOT_CHATID=
CEKIM_BOT_TOKEN=
CEKIM_BOT_CHATID=
DEKONT_BOT_TOKEN=
DEKONT_BOT_CHATID=
VERGI_BOT_TOKEN=
VERGI_BOT_CHATID=

# ─── İlan URL içe aktarma (opsiyonel) ─────────────────────────────────────
# Boşsa Vercel doğrudan hedef URL’ye fetch eder. Doluysa tüm import istekleri bu HTTPS URL’ye
# POST { "url": "..." } gider; yanıt JSON { "html": "..." } veya düz HTML olmalıdır.
# IMPORT_LISTING_FETCH_DELEGATE_SECRET varsa Authorization: Bearer … gönderilir.
# IMPORT_LISTING_FETCH_DELEGATE=
# IMPORT_LISTING_FETCH_DELEGATE_SECRET=

# ─── Node (Vercel genelde kendisi ayarlar; sabitlemek istersen) ───────────
NODE_ENV=production

# ─── Sadece lokal / CI: Postgres DDL (npm run db:apply) — Vercel’de zorunlu DEĞİL ─
# Supabase → Settings → Database → Connection string → URI (Direct, port 5432)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.mdoffvnavmjvxfsyznfr.supabase.co:5432/postgres
