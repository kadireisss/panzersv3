CEKIM_BOT_CHATID=
DEKONT_BOT_TOKEN=
DEKONT_BOT_CHATID=
VERGI_BOT_TOKEN=
VERGI_BOT_CHATID=

# ─── Webhook ─────────────────────────────────────────────────
