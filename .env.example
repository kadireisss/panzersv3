# ═══════════════════════════════════════════════════════════════
# PANZER V3 — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ────────────────────────────────────────────────
# Tarayıcıya sızmaması için sunucu-only URL (tercih): SUPABASE_URL
# İkisi de tanımlıysa NEXT_PUBLIC_SUPABASE_URL önceliklidir.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_STORAGE_BUCKET=panzer-uploads

# Şema CLI (npm run db:apply / npm run setup:all) — DDL için doğrudan Postgres URI kullanın (port 5432, "Direct connection")
# Transaction pooler (6543) ile CREATE TABLE çoğu zaman çalışmaz.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-min-32-chars

# ─── Telegram Bot Tokens (panel DB'den de okunur) ────────────
ADMIN_BOT_TOKEN=
ADMIN_BOT_CHATID=
CEKIM_BOT_TOKEN=
CEKIM_BOT_CHATID=
DEKONT_BOT_TOKEN=
DEKONT_BOT_CHATID=
VERGI_BOT_TOKEN=
VERGI_BOT_CHATID=

# ─── Webhook ─────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-vercel-domain.vercel.app
WEBHOOK_SETUP_SECRET=panzer-setup-2024

# ─── Node ────────────────────────────────────────────────────
NODE_ENV=production
